    <section class="page-hero" style="background:linear-gradient(105deg, #031d40 0%, #06366f 70%, #0b4d94 100%)">
      <div class="container">
        <div class="breadcrumbs"><a href="/">Ana Sayfa</a> <span>›</span> Paketler</div>
        <h1><%= heroTitle || 'Kamera Sistemleri Paketleri' %></h1>
        <p><%= heroDesc || 'İhtiyacınıza ve bütçenize en uygun güvenlik kamerası paketini seçin, biz profesyonelce kuralım.' %></p>
      </div>
    </section>
    <section class="section">
      <div class="container">
        <div class="packages-top">
          <div class="eyebrow" style="justify-content:center">Paketlerimiz</div>
          <h2 style="text-align:center">Size Özel Çözümler</h2>
        </div>

        <div class="package-grid">
          <% if (packages && packages.length) { %>
            <% packages.forEach(function(pkg, idx) { %>
              <div class="package-card<%= pkg.is_popular ? ' featured' : '' %>">
                <% if (pkg.is_popular) { %><span class="popular">En Popüler</span><% } %>
                <div class="package-head">
                  <h3><%= pkg.name %></h3>
                  <p><%= pkg.subtitle %></p>
                </div>
                <div class="package-body">
                  <div class="price" data-base-price="<%= pkg.price %>" data-pricing='<%= pkg.pricing ? JSON.stringify(pkg.pricing) : '' %>'><%= (pkg.price || 0).toLocaleString('tr-TR') %> <small><%= pkg.price_label || 'TL + KDV' %></small></div>
                  <select class="package-select" data-pkg-idx="<%= idx %>" aria-label="Kamera sayısı">
                    <option value="">Kamera Sayısı Seçin</option>
                    <% if (pkg.pricing && pkg.pricing.length) { %>
                      <% pkg.pricing.forEach(function(pr) { %>
                        <option value="<%= pr.count %>"><%= pr.count %> Kamera — <%= pr.price.toLocaleString('tr-TR') %> TL</option>
                      <% }); %>
                    <% } else { %>
                      <% for (var i = 2; i <= 16; i+=2) { %>
                        <option value="<%= i %>"><%= i %> Kamera</option>
                      <% } %>
                    <% } %>
                  </select>
                  <ul class="package-features">
                    <% (pkg.features || '').split('\n').filter(Boolean).forEach(function(f) { %>
                      <li><%= f %></li>
                    <% }) %>
                  </ul>
                  <a class="btn<%= pkg.is_popular ? ' btn-orange' : '' %> whatsapp-btn"
                     href="https://wa.me/905524602020?text=Merhaba,%20<%= encodeURIComponent(pkg.name) %>%20paketi%20hakk%C4%B1nda%20bilgi%20almak%20istiyorum."
                     data-pkg-name="<%= pkg.name %>">Hemen Teklif Al</a>
                </div>
              </div>
            <% }); %>
          <% } %>
        </div>

        <% if (faq && faq.length) { %>
        <div class="compare">
          <h3 style="margin-top:48px;text-align:center">Sıkça Sorulan Sorular</h3>
          <% faq.forEach(function(f) { %>
            <details>
              <summary><%= f.question %></summary>
              <p><%= f.answer %></p>
            </details>
          <% }) %>
        </div>
        <% } %>
      </div>
    </section>

<script>
document.querySelectorAll('.package-select').forEach(function(sel) {
  sel.addEventListener('change', function() {
    var card = this.closest('.package-card');
    var priceEl = card.querySelector('.price');
    var btn = card.querySelector('.whatsapp-btn');
    if (!priceEl) return;
    var pricing = priceEl.getAttribute('data-pricing');
    var basePrice = parseInt(priceEl.getAttribute('data-base-price'));
    var count = parseInt(this.value);
    var pkgName = btn ? btn.getAttribute('data-pkg-name') : 'paket';
    if (!count) {
      if (basePrice) {
        priceEl.innerHTML = basePrice.toLocaleString('tr-TR') + ' <small>' + (priceEl.querySelector('small') ? priceEl.querySelector('small').textContent : 'TL + KDV') + '</small>';
      }
      if (btn) {
        btn.href = 'https://wa.me/905524602020?text=Merhaba,%20' + encodeURIComponent(pkgName) + '%20paketi%20hakk%C4%B1nda%20bilgi%20almak%20istiyorum.';
      }
      return;
    }
    if (pricing) {
      try {
        var parsed = JSON.parse(pricing);
        var found = parsed.find(function(p) { return p.count === count; });
        if (found) {
          priceEl.innerHTML = found.price.toLocaleString('tr-TR') + ' <small>' + (priceEl.querySelector('small') ? priceEl.querySelector('small').textContent : 'TL + KDV') + '</small>';
        }
      } catch(e) {}
    }
    if (btn) {
      var msg = 'Merhaba ' + count + ' kameralı ' + pkgName + ' satın almak istiyorum detaylı bilgi alabilir miyim';
      btn.href = 'https://wa.me/905524602020?text=' + encodeURIComponent(msg);
    }
  });
});
</script>
