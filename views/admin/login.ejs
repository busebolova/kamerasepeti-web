  <div style="display:grid;place-items:center;min-height:100vh;background:linear-gradient(135deg,#021b3b,#062e63)">
    <div style="background:#fff;border-radius:22px;padding:40px;width:100%;max-width:400px;box-shadow:0 25px 60px rgba(2,27,59,.3)">
      <div style="text-align:center;margin-bottom:32px">
        <img src="<%= logoDark %>" alt="<%= siteName %>" style="width:220px;height:50px;object-fit:contain;margin:0 auto">
        <p style="color:var(--muted);margin-top:12px">Yönetim Paneli</p>
      </div>
      <% if (typeof error !== 'undefined' && error) { %><div style="background:#fee7e1;color:#b91c1c;padding:10px 14px;border-radius:10px;margin-bottom:16px;font-size:14px"><%= error %></div><% } %>
      <form method="post" action="/admin/login">
        <div style="margin-bottom:16px">
          <label style="display:block;margin-bottom:6px;font-size:13px;color:var(--navy);font-weight:700">Kullanıcı Adı</label>
          <input name="username" style="width:100%;padding:12px 14px;border:1px solid #dbe2ec;border-radius:10px;font-size:15px;outline:none;box-sizing:border-box" required>
        </div>
        <div style="margin-bottom:24px">
          <label style="display:block;margin-bottom:6px;font-size:13px;color:var(--navy);font-weight:700">Şifre</label>
          <input type="password" name="password" style="width:100%;padding:12px 14px;border:1px solid #dbe2ec;border-radius:10px;font-size:15px;outline:none;box-sizing:border-box" required>
        </div>
        <button class="btn btn-orange" type="submit" style="width:100%;min-height:50px">Giriş Yap</button>
      </form>
    </div>
  </div>
