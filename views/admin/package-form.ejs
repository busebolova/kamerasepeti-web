  <div class="admin-topbar">
    <h1><%= p ? 'Paketi Düzenle' : 'Yeni Paket' %></h1>
    <a href="/admin/paketler" class="btn btn-sm" style="min-height:auto;background:var(--muted)">← Geri</a>
  </div>
  <div class="admin-card">
    <form class="admin-form" method="post" action="/admin/paketler/kaydet">
      <% if (p) { %><input type="hidden" name="id" value="<%= p.id %>"><% } %>
      <div class="row">
        <div>
          <label>Paket Adı</label>
          <input name="name" value="<%= p ? p.name : '' %>" required>
        </div>
        <div>
          <label>Slug (URL)</label>
          <input name="slug" value="<%= p ? p.slug : '' %>" placeholder="baslangic-paketi" required>
        </div>
      </div>
      <div class="row">
        <div>
          <label>Altyazı</label>
          <input name="subtitle" value="<%= p ? p.subtitle : '' %>" placeholder="4 Kameralı Sistem">
        </div>
        <div>
          <label>Fiyat (TL)</label>
          <input type="number" name="price" value="<%= p ? p.price : 0 %>">
        </div>
      </div>
      <div class="row">
        <div>
          <label>Fiyat Etiketi</label>
          <input name="price_label" value="<%= p ? p.price_label : 'TL + KDV' %>">
        </div>
        <div>
          <label>Sıralama</label>
          <input type="number" name="sort_order" value="<%= p ? p.sort_order : 0 %>">
        </div>
      </div>
      <label>Özellikler (her satıra bir özellik)</label>
      <textarea name="features" rows="8" style="font-family:monospace"><%= p ? p.features : '' %></textarea>
      <div style="display:flex;gap:20px;margin-top:14px">
        <label style="display:flex;align-items:center;gap:8px">
          <input type="checkbox" name="is_popular" value="1" <%= p && p.is_popular ? 'checked' : '' %> style="width:auto">
          Popüler Paket
        </label>
        <label style="display:flex;align-items:center;gap:8px">
          <input type="checkbox" name="is_published" value="1" <%= p && !p.is_published ? '' : 'checked' %> style="width:auto">
          Yayında
        </label>
      </div>
      <div class="admin-actions">
        <button type="submit" class="btn btn-orange" style="min-height:auto">Kaydet</button>
      </div>
    </form>
  </div>
