<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= typeof title !== 'undefined' ? title + ' | ' : '' %>Admin Panel - <%= siteName %></title>
  <link rel="icon" type="image/png" href="<%= favicon %>">
  <link rel="stylesheet" href="/styles.css">
  <style>
    .admin-body { background:#f0f4f9;padding-bottom:0 !important }
    .admin-body .site-header { display:none }
    .admin-body .floating-whatsapp { display:none }
    .admin-layout { display:flex;min-height:100vh }
    .admin-sidebar { width:240px;background:#021b3b;color:#fff;padding:20px 0;flex-shrink:0 }
    .admin-sidebar a { display:flex;align-items:center;gap:8px;padding:10px 20px;color:#b7c8de;font-size:14px;font-weight:600;transition:.2s }
    .admin-sidebar a:hover, .admin-sidebar a.active { color:#fff;background:rgba(255,255,255,.08) }
    .admin-sidebar .logo { padding:0 20px 20px;border-bottom:1px solid rgba(255,255,255,.1);margin-bottom:16px }
    .admin-sidebar .logo img { width:180px;height:40px;object-fit:contain;object-position:left }
    .admin-main { flex:1;padding:24px 32px;overflow-y:auto }
    .admin-topbar { display:flex;justify-content:space-between;align-items:center;margin-bottom:28px;padding-bottom:16px;border-bottom:1px solid var(--line) }
    .admin-topbar h1 { font-size:24px;margin-bottom:0 }
    .admin-card { background:#fff;border:1px solid var(--line);border-radius:14px;padding:20px;margin-bottom:20px }
    .admin-grid { display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:16px;margin-bottom:28px }
    .stat-card { background:#fff;border:1px solid var(--line);border-radius:14px;padding:20px;text-align:center }
    .stat-card b { display:block;font-size:32px;color:var(--orange);margin-bottom:4px }
    .stat-card span { color:var(--muted);font-size:13px }
    .admin-table { width:100%;border-collapse:collapse;font-size:14px }
    .admin-table th { text-align:left;padding:10px 12px;border-bottom:2px solid var(--line);color:var(--muted);font-weight:700;font-size:12px;text-transform:uppercase }
    .admin-table td { padding:10px 12px;border-bottom:1px solid var(--line);vertical-align:middle }
    .admin-table tr:hover td { background:#fafbfc }
    .badge { display:inline-block;padding:2px 8px;border-radius:99px;font-size:11px;font-weight:700 }
    .badge-green { background:#e3f7ea;color:var(--green) }
    .badge-red { background:#fee7e1;color:var(--orange) }
    .btn-sm { padding:6px 14px;min-height:auto;font-size:13px }
    .admin-form label { display:block;margin-bottom:5px;font-size:13px;color:var(--navy);font-weight:700;margin-top:14px }
    .admin-form input, .admin-form textarea, .admin-form select { width:100%;padding:10px 12px;border:1px solid #dbe2ec;border-radius:8px;font-size:14px;outline:none;box-sizing:border-box }
    .admin-form input:focus, .admin-form textarea:focus { border-color:var(--blue);box-shadow:0 0 0 3px rgba(11,77,148,.08) }
    .admin-form textarea { min-height:120px;resize:vertical }
    .admin-form .row { display:grid;grid-template-columns:1fr 1fr;gap:16px }
    .admin-actions { display:flex;gap:8px;margin-top:20px }
    .btn-danger { background:#dc2626 }
    .btn-danger:hover { background:#b91c1c }
    .media-grid { display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:12px }
    .media-item { border:1px solid var(--line);border-radius:10px;overflow:hidden;background:#fff }
    .media-item img, .media-item video { width:100%;height:120px;object-fit:cover;display:block }
    .media-item .info { padding:8px;font-size:11px;color:var(--muted) }
    .media-item .info .del { float:right;color:var(--orange);cursor:pointer;border:0;background:none;font-size:13px }
    .sort-col { width:50px }
    .action-col { width:120px }
    .ck-content { min-height:400px }
    @media(max-width:768px){ .admin-layout{flex-direction:column} .admin-sidebar{width:100%;padding:10px 0} .admin-sidebar a{padding:8px 16px} .admin-main{padding:16px} .admin-form .row{grid-template-columns:1fr} }
  </style>
</head>
<body class="admin-body">
  <div class="admin-layout">
    <nav class="admin-sidebar">
      <div class="logo"><a href="/admin"><img src="<%= logoLight %>" alt="<%= siteName %>"></a></div>
      <a href="/admin" class="<%= currentPath === '/admin' ? 'active' : '' %>">📊 Dashboard</a>
      <a href="/admin/blog" class="<%= currentPath.startsWith('/admin/blog') ? 'active' : '' %>">📝 Blog</a>
      <a href="/admin/referanslar" class="<%= currentPath.startsWith('/admin/referanslar') ? 'active' : '' %>">⭐ Referanslar</a>
      <a href="/admin/projeler" class="<%= currentPath.startsWith('/admin/projeler') ? 'active' : '' %>">🏗️ Projeler</a>
      <a href="/admin/paketler" class="<%= currentPath.startsWith('/admin/paketler') ? 'active' : '' %>">📦 Paketler</a>
      <a href="/admin/menu" class="<%= currentPath.startsWith('/admin/menu') ? 'active' : '' %>">📋 Menü</a>
      <a href="/admin/footer" class="<%= currentPath.startsWith('/admin/footer') ? 'active' : '' %>">🔻 Footer</a>
      <a href="/admin/iletisim" class="<%= currentPath.startsWith('/admin/iletisim') ? 'active' : '' %>">📞 İletişim</a>
      <a href="/admin/medya" class="<%= currentPath.startsWith('/admin/medya') ? 'active' : '' %>">🖼️ Medya</a>
      <a href="/admin/ayarlar" class="<%= currentPath.startsWith('/admin/ayarlar') ? 'active' : '' %>">⚙️ Ayarlar</a>
      <div style="border-top:1px solid rgba(255,255,255,.1);margin:16px 20px 0;padding-top:16px">
        <a href="/" target="_blank">🌐 Siteyi Gör</a>
        <a href="/admin/logout">🚪 Çıkış</a>
      </div>
    </nav>
    <div class="admin-main">
      <%- body %>
    </div>
  </div>
</body>
</html>
