<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= typeof title !== 'undefined' ? title + ' | ' : '' %>Admin Panel - <%= siteName %></title>
  <link rel="icon" type="image/png" href="<%= favicon %>">
  <link rel="stylesheet" href="/assets/styles.css">
  <style>
    .admin-body { background:#f0f4f9;padding-bottom:0 !important }
    .admin-body .site-header { display:none }
    .admin-body .floating-whatsapp { display:none }
    .admin-body .nav-links { display:none !important }
    .admin-layout { display:flex;min-height:100vh }
    .admin-sidebar { width:240px;background:#021b3b;color:#fff;padding:20px 0;flex-shrink:0 }
    .admin-sidebar a { display:flex;align-items:center;gap:8px;padding:10px 20px;color:#b7c8de;font-size:14px;font-weight:600;transition:.2s }
    .admin-sidebar a:hover, .admin-sidebar a.active { color:#fff;background:rgba(255,255,255,.08) }
    .admin-sidebar .logo { padding:0 20px 20px;border-bottom:1px solid rgba(255,255,255,.1);margin-bottom:16px }
    .admin-sidebar .logo img { width:180px;height:40px;object-fit:contain;object-position:left }
    .admin-main { flex:1;padding:24px 32px;overflow-y:auto }
    .admin-topbar { display:flex;justify-content:space-between;align-items:center;margin-bottom:28px;padding-bottom:16px;border-bottom:1px solid var(--line) }
    .admin-topbar h1 { font-size:24px;margin-bottom:0 }
    .admin-card { background:#fff;border:1px solid var(--line);border-radius:14px;padding:20px;margin-bottom:20px }
    .admin-grid { display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:16px;margin-bottom:28px }
    .stat-card { background:#fff;border:1px solid var(--line);border-radius:14px;padding:20px;text-align:center }
    .stat-card b { display:block;font-size:32px;color:var(--orange);margin-bottom:4px }
    .stat-card span { color:var(--muted);font-size:13px }
    .admin-table { width:100%;border-collapse:collapse;font-size:14px }
    .admin-table th { text-align:left;padding:10px 12px;border-bottom:2px solid var(--line);color:var(--muted);font-weight:700;font-size:12px;text-transform:uppercase }
    .admin-table td { padding:10px 12px;border-bottom:1px solid var(--line);vertical-align:middle }
    .admin-table tr:hover td { background:#fafbfc }
    .badge { display:inline-block;padding:2px 8px;border-radius:99px;font-size:11px;font-weight:700 }
    .badge-green { background:#e3f7ea;color:var(--green) }
    .badge-red { background:#fee7e1;color:var(--orange) }
    .btn-sm { padding:6px 14px;min-height:auto;font-size:13px }
    .admin-form label { display:block;margin-bottom:5px;font-size:13px;color:var(--navy);font-weight:700;margin-top:14px }
    .admin-form input, .admin-form textarea, .admin-form select { width:100%;padding:10px 12px;border:1px solid #dbe2ec;border-radius:8px;font-size:14px;outline:none;box-sizing:border-box }
    .admin-form input:focus, .admin-form textarea:focus { border-color:var(--blue);box-shadow:0 0 0 3px rgba(11,77,148,.08) }
    .admin-form textarea { min-height:120px;resize:vertical }
    .admin-form .row { display:grid;grid-template-columns:1fr 1fr;gap:16px }
    .admin-actions { display:flex;gap:8px;margin-top:20px }
    .btn-danger { background:#dc2626 }
    .btn-danger:hover { background:#b91c1c }
    .media-grid { display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:12px }
    .media-item { border:1px solid var(--line);border-radius:10px;overflow:hidden;background:#fff }
    .media-item img, .media-item video { width:100%;height:120px;object-fit:cover;display:block }
    .media-item .info { padding:8px;font-size:11px;color:var(--muted) }
    .media-item .info .del { float:right;color:var(--orange);cursor:pointer;border:0;background:none;font-size:13px }
    .sort-col { width:50px }
    .action-col { width:120px }
    .ck-content { min-height:400px }
    @media(max-width:768px){ .admin-layout{flex-direction:column} .admin-sidebar{width:100%;padding:10px 0} .admin-sidebar a{padding:8px 16px} .admin-main{padding:16px} .admin-form .row{grid-template-columns:1fr} }
  </style>
</head>
<body class="admin-body">
  <div class="admin-layout">
    <nav class="admin-sidebar">
      <div class="logo"><a href="/admin"><img src="<%= logoLight %>" alt="<%= siteName %>"></a></div>
      <a href="/admin" class="<%= currentPath === '/admin' ? 'active' : '' %>"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg> Dashboard</a>
      <a href="/admin/blog" class="<%= currentPath.startsWith('/admin/blog') ? 'active' : '' %>"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg> Blog</a>
      <a href="/admin/referanslar" class="<%= currentPath.startsWith('/admin/referanslar') ? 'active' : '' %>"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg> Referanslar</a>
      <a href="/admin/projeler" class="<%= currentPath.startsWith('/admin/projeler') ? 'active' : '' %>"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg> Projeler</a>
      <a href="/admin/paketler" class="<%= currentPath.startsWith('/admin/paketler') ? 'active' : '' %>"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg> Paketler</a>
      <a href="/admin/menu" class="<%= currentPath.startsWith('/admin/menu') ? 'active' : '' %>"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg> Menü</a>
      <a href="/admin/footer" class="<%= currentPath.startsWith('/admin/footer') ? 'active' : '' %>"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg> Footer</a>
      <a href="/admin/iletisim" class="<%= currentPath.startsWith('/admin/iletisim') ? 'active' : '' %>"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg> İletişim</a>
      <a href="/admin/medya" class="<%= currentPath.startsWith('/admin/medya') ? 'active' : '' %>"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg> Medya</a>
      <a href="/admin/ayarlar" class="<%= currentPath.startsWith('/admin/ayarlar') ? 'active' : '' %>"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg> Ayarlar</a>
      <div style="border-top:1px solid rgba(255,255,255,.1);margin:16px 20px 0;padding-top:16px">
        <a href="/" target="_blank"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg> Siteyi Gör</a>
        <a href="/admin/logout"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg> Çıkış</a>
      </div>
    </nav>
    <div class="admin-main">
      <%- body %>
    </div>
  </div>
</body>
</html>
