  <div class="preloader" aria-hidden="true"><img src="<%= favicon %>" alt=""></div>
  <header class="site-header">
    <div class="container nav">
      <a class="brand" href="/"><img src="<%= logoDark %>" alt="<%= siteName %>"></a>
      <nav class="nav-links">
        <% navItems.forEach(function(item) { %>
          <a href="<%= item.url %>" <%= currentPath === item.url ? 'class="active"' : '' %>><%= item.label %></a>
        <% }) %>
      </nav>
      <a class="nav-phone" href="tel:<%= sitePhone.replace(/[^0-9]/g, '') %>">
        <span class="phone-icon">☎</span>
        <span><%= sitePhone %><small>WhatsApp Teklif Hattı</small></span>
      </a>
      <button class="menu-toggle" aria-label="Menüyü aç">☰</button>
    </div>
  </header>
  <main>
    <section class="page-hero" style="background:linear-gradient(105deg, #031d40 0%, #06366f 70%, #0b4d94 100%)">
      <div class="container">
        <div class="breadcrumbs"><a href="/">Ana Sayfa</a> <span>›</span> Blog</div>
        <h1>Güvenlik Kamerası Blogu</h1>
        <p>Güvenlik kamerası sistemleri, kurulum ipuçları ve sektördeki yenilikler hakkında bilgilendirici içerikler.</p>
      </div>
    </section>
    <section class="section">
      <div class="container">
        <div class="blog-layout">
          <div>
            <div class="blog-grid">
              <% posts.forEach(function(post) { %>
                <a href="/blog/<%= post.slug %>" class="blog-card" style="display:block;color:inherit">
                  <div class="blog-image"><img src="<%= post.image || '/assets/hero-kurulum-v2.webp' %>" alt="<%= post.title %>" loading="lazy"></div>
                  <div class="card-body">
                    <% if (post.category) { %><span class="tag"><%= post.category %></span><% } %>
                    <div class="meta"><%= post.published_at ? new Date(post.published_at).toLocaleDateString('tr-TR',{year:'numeric',month:'long',day:'numeric'}) : '' %> · <%= post.reading_time %></div>
                    <h3><%= post.title %></h3>
                    <p><%= post.summary %></p>
                    <span class="text-link">Devamını Oku →</span>
                  </div>
                </a>
              <% }) %>
            </div>
          </div>
          <aside class="sidebar">
            <div class="sidebar-box">
              <h3>Kategoriler</h3>
              <ul class="category-list">
                <% categories.forEach(function(c) { %>
                  <li><%= c.category %> <span><%= c.count %></span></li>
                <% }) %>
              </ul>
            </div>
            <div class="sidebar-box" style="background:var(--navy);color:#fff">
              <h3 style="color:#fff;border-color:rgba(255,255,255,.15)">Size Özel Teklif</h3>
              <p style="color:#cbd8e9;font-size:14px">İhtiyacınıza özel kamera sistemi ve fiyat teklifi için hemen iletişime geçin.</p>
              <a class="btn btn-orange" href="/iletisim" style="width:100%">Teklif Alın</a>
            </div>
          </aside>
        </div>
      </div>
    </section>
  </main>
