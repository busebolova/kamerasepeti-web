  <div class="preloader" aria-hidden="true"><img src="<%= favicon %>" alt=""></div>
  <header class="site-header">
    <div class="container nav">
      <a class="brand" href="/"><img src="<%= logoDark %>" alt="<%= siteName %>"></a>
      <nav class="nav-links">
        <% navItems.forEach(function(item) { %>
          <%
            const shortLabels = {
              'Ana Sayfa': 'Ana',
              'Paketler': 'Paket',
              'Hizmetlerimiz': 'Hiz.',
              'Hakkımızda': 'Hakk.',
              'Referanslar': 'Ref.',
              'Blog': 'Blog',
              'İletişim': 'İlet.'
            };
            const navIcons = {
              'Ana Sayfa': '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 10.5 12 3l9 7.5"/><path d="M5 9.5V21h14V9.5"/><path d="M9 21v-6h6v6"/></svg>',
              'Paketler': '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M21 8.5 12 3 3 8.5l9 5.5 9-5.5Z"/><path d="M3 8.5V16l9 5 9-5V8.5"/><path d="M12 14v7"/></svg>',
              'Hizmetlerimiz': '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M14.7 6.3a4 4 0 0 0-5 5L4 17l3 3 5.7-5.7a4 4 0 0 0 5-5l-2.6 2.6-3-3 2.6-2.6Z"/></svg>',
              'Hakkımızda': '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18Z"/><path d="M12 11v6"/><path d="M12 7h.01"/></svg>',
              'Referanslar': '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20 7 9 18l-5-5"/><path d="M16 7h4v4"/></svg>',
              'Blog': '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 4h14v16H5z"/><path d="M8 8h8"/><path d="M8 12h8"/><path d="M8 16h5"/></svg>',
              'İletişim': '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.4 19.4 0 0 1-6-6A19.8 19.8 0 0 1 2.1 4.2 2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1.9.3 1.7.6 2.5a2 2 0 0 1-.5 2.1L8 9.5a16 16 0 0 0 6.5 6.5l1.2-1.2a2 2 0 0 1 2.1-.5c.8.3 1.6.5 2.5.6a2 2 0 0 1 1.7 2Z"/></svg>'
            };
            const isActive = currentPath === item.url || (item.url !== '/' && currentPath.startsWith(item.url));
          %>
          <a href="<%= item.url %>" class="<%= isActive ? 'active' : '' %>"><span class="nav-icon"><%- navIcons[item.label] || navIcons['Ana Sayfa'] %></span><span class="nav-text nav-text-full"><%= item.label %></span><span class="nav-text nav-text-short"><%= shortLabels[item.label] || item.label %></span></a>
        <% }) %>
      </nav>
      <a class="nav-phone" href="tel:<%= sitePhone.replace(/[^0-9]/g, '') %>">
        <span class="phone-icon">☎</span>
        <span><%= sitePhone %><small>WhatsApp Teklif Hattı</small></span>
      </a>
      <button class="menu-toggle" aria-label="Menüyü aç">☰</button>
    </div>
  </header>
