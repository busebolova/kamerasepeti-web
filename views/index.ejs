    </div>
    <div class="service-grid">
      <% services.forEach(function(svc) { %>
        <div class="service-card">
          <div class="service-photo"><img src="<%= svc.image %>" alt="<%= svc.title %>" loading="lazy"></div>
          <div class="card-body">
            <h3><%= svc.title %></h3>
            <p><%= svc.desc %></p>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</section>

