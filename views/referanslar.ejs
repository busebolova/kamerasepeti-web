<section class="refs-herostyle="--ref-bg: url(<%= refHeroBg %>)">
  <div class="container">
    <div class="breadcrumbs"><a href="/">Ana Sayfa</a> <span>›</span> Referanslar</div>
    <h1>Referanslarımız</h1>
    <p>Gerçekleştirdiğimiz projeler ve iş ortaklarımızla güvenliği en üst seviyeye taşıyoruz.</p>
  </div>
</section>

<section class="section refs-page">
  <div class="container">
    <div class="refs-title">
      <span class="refs-title-icon">▣</span>
      <div>
        <h2>Tamamlanan Projelerimiz</h2>
        <p>Farklı sektörlerde birçok projeyi başarıyla tamamladık.</p>
      </div>
    </div>

    <div class="refs-project-types">
      <article>
        <img src="/assets/about-banner.webp" alt="Apartman kamera sistemi kurulumu">
        <div><span>▥</span><strong>Apartman</strong><small>Kamera Sistemleri</small></div>
      </article>
      <article>
        <img src="/assets/ev-kamera-sistemi.webp" alt="Villa kamera sistemi projesi">
        <div><span>⌂</span><strong>Villa</strong><small>Kamera Sistemleri</small></div>
      </article>
      <article>
        <img src="/assets/is-yeri-kamera-sistemi.webp" alt="Mağaza güvenlik kamerası kurulumu">
        <div><span>▤</span><strong>Mağaza</strong><small>Kamera Sistemleri</small></div>
      </article>
      <article>
        <img src="/assets/about-consultation.webp" alt="Ofis kamera sistemi çözümü">
        <div><span>▦</span><strong>Ofis</strong><small>Kamera Sistemleri</small></div>
      </article>
      <article>
        <img src="/assets/service-technical.webp" alt="Depo ve fabrika kamera sistemi">
        <div><span>▧</span><strong>Depo & Fabrika</strong><small>Kamera Sistemleri</small></div>
      </article>
    </div>

    <div class="refs-title refs-title-space">
      <span class="refs-title-icon">◇</span>
      <div>
        <h2>Çalıştığımız Markalar</h2>
        <p>Projelerimizde güvenlik ve ağ altyapısında kabul görmüş markaları tercih ediyoruz.</p>
      </div>
    </div>

    <div class="refs-brands" aria-label="Çalıştığımız güvenlik markaları">
      <div class="brand-logo hikvision">HIKVISION</div>
      <div class="brand-logo dahua">dahua <small>TECHNOLOGY</small></div>
      <div class="brand-logo unv">UNV <small>Uniview</small></div>
      <div class="brand-logo uniywell">UNIYWELL</div>
      <div class="brand-logo tplink">tp-link</div>
      <div class="brand-logo nexans">Nexans</div>
    </div>

    <div class="refs-before-after">
      <div class="refs-title compact">
        <span class="refs-title-icon">◉</span>
        <div>
          <h2>Öncesi / Sonrası</h2>
          <p>Düzenli kurulum, güçlü altyapı. Güvenli yarınlar.</p>
        </div>
      </div>
      <article class="before-card">
        <span class="badge-red">Öncesi</span>
        <div class="before-visual before-bad"></div>
        <p><b>✕</b> Dağınık kablolama, güvensiz ve düzensiz sistem</p>
      </article>
      <article class="before-card">
        <span class="badge-green">Sonrası</span>
        <div class="before-visual before-good"></div>
        <p><b>✓</b> Düzenli kablolama, güvenli ve profesyonel kurulum</p>
      </article>
    </div>

    <div class="refs-title refs-title-space">
      <span class="refs-title-icon">☆</span>
      <div>
        <h2>Müşteri Yorumları</h2>
      </div>
    </div>

    <div class="refs-testimonials">
      <% const shownTestimonials = testimonials && testimonials.length ? testimonials.slice(0, 3) : [
        { name: 'Mehmet Y.', title: 'İstanbul', content: 'İşyerimiz için kurulan sistemden çok memnun kaldık.', rating: 5 },
        { name: 'Selin A.', title: 'İstanbul', content: 'Kurulum temiz ve hızlı yapıldı. Ekibin ilgisi için teşekkür ederiz.', rating: 5 },
        { name: 'Ahmet D.', title: 'İstanbul', content: 'Telefondan izleme kurulumu sorunsuz çalışıyor.', rating: 5 }
      ]; %>
      <% shownTestimonials.forEach(function(t) { %>
        <article>
          <div class="quote-mark">“</div>
          <div class="stars"><% for (var s = 0; s < (t.rating || 5); s++) { %>★<% } %></div>
          <p><%= t.content %></p>
          <div class="person"><span><%= t.name.charAt(0) %></span><strong><%= t.name %></strong><small><%= t.title || t.company || 'İstanbul' %></small></div>
        </article>
      <% }) %>
    </div>

    <div class="refs-trust-row">
      <article class="refs-istanbul">
        <span>⌖</span>
        <h2>İstanbul Genelinde Keşif ve Kurulum Hizmeti</h2>
        <p>Avrupa ve Anadolu Yakası'nda profesyonel kamera sistemleri kurulumu, teknik servis ve bakım hizmeti sunuyoruz.</p>
        <em>İstanbul</em>
      </article>
      <article class="refs-why">
        <h2>Güveninizi Hak Ediyoruz</h2>
        <div>
          <span>✓</span><strong>Profesyonel Kurulum</strong><small>Temiz ve güvenli montaj</small>
        </div>
        <div>
          <span>▯</span><strong>Mobil İzleme Desteği</strong><small>Android ve iPhone uyumlu</small>
        </div>
        <div>
          <span>⚙</span><strong>Teknik Servis</strong><small>7/24 destek ve hızlı çözüm</small>
        </div>
        <div>
          <span>⚡</span><strong>Altyapı Desteği</strong><small>Network ve kablolama çözümü</small>
        </div>
        <div>
          <span>☆</span><strong>Memnuniyet Garantisi</strong><small>Öncelikli çalışma anlayışı</small>
        </div>
        <div>
          <span>⌖</span><strong>İstanbul Geneli Hizmet</strong><small>Keşif ve kurulum hizmeti</small>
        </div>
      </article>
    </div>

    <section class="refs-cta">
      <div>
        <span>◇</span>
        <h2>Siz de Referanslarımız Arasına Katılın!</h2>
        <p>Ücretsiz keşif ve ihtiyacınıza özel çözümler için hemen bizimle iletişime geçin.</p>
      </div>
      <a class="btn btn-green" href="<%= whatsappUrl %>" target="_blank">WhatsApp'tan Ücretsiz Keşif Talep Edin</a>
      <div class="refs-cta-contact">
        <strong><%= sitePhone %></strong>
        <small>WhatsApp Teklif Hattı</small>
        <strong>7/24 Teknik Destek</strong>
      </div>
    </section>
  </div>
</section>
