<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= typeof title !== 'undefined' ? title + ' | ' + siteName : siteName %></title>
  <meta name="description" content="<%= typeof metaDesc !== 'undefined' ? metaDesc : 'Profesyonel güvenlik kamerası çözümleri.' %>">
  <meta name="robots" content="index, follow">
  <link rel="icon" type="image/png" href="<%= favicon %>">
  <link rel="stylesheet" href="/styles.css">
  <%- typeof headExtra !== 'undefined' ? headExtra : '' %>
</head>
<body>
  <%- include('partials/header') %>
  <main>
    <%- body %>
  </main>
  <%- include('partials/footer') %>
  <a class="floating-whatsapp" href="<%= whatsappUrl %>" aria-label="WhatsApp'tan yaz">◉</a>
  <script src="/app.js"></script>
</body>
</html>
