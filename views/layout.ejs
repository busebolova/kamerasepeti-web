<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= typeof title !== 'undefined' ? title + ' | ' + siteName : siteName %></title>
  <meta name="description" content="<%= typeof metaDesc !== 'undefined' ? metaDesc : 'Profesyonel güvenlik kamerası çözümleri.' %>">
  <meta name="robots" content="index, follow">
  <link rel="icon" type="image/png" href="<%= favicon %>">
  <link rel="stylesheet" href="/assets/styles.css">
  <%- typeof headExtra !== 'undefined' ? headExtra : '' %>
</head>
<body>
  <%- include('partials/header') %>
  <main>
    <%- body %>
  </main>
  <%- include('partials/footer') %>
  <a class="floating-whatsapp" href="<%= whatsappUrl %>" target="_blank" aria-label="WhatsApp'tan yaz">
    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
  </a>
  <script src="/assets/app.js"></script>
</body>
</html>
